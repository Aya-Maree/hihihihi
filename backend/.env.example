# ─── App settings ──────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ─── RAG settings ──────────────────────────────────────────────────────────
# Sentence transformer model for embeddings (as specified in Deliverable 1)
