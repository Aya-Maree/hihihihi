GOOGLE_API_KEY=AIzaSyDR7-CljLrcmswSeXqlWi4NhXC1QdEFjMU

# Gemini model to use (free options: gemini-1.5-flash, gemini-1.5-pro)
GEMINI_MODEL=gemini-1.5-flash

# ─── Spoonacular Food API (Tier 2 — optional) ──────────────────────────────
